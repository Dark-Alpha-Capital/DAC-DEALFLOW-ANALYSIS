{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "AUTH_SECRET",
        "REDIS_URL",
        "AI_API_KEY",
        "RESEND_API_KEY",
        "NEXTCLOUD_URL",
        "NEXTCLOUD_USER",
        "NEXTCLOUD_PASSWORD",
        "BITRIX_SECRET_KEY",
        "BITRIX24_WEBHOOK",
        "BITRIX24_PORTAL_BASE",
        "BITRIX_DEFAULT_STAGE_ID",
        "BITRIX_DEAL_STAGES_JSON",
        "GOOGLE_AI_API_KEY"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "build"
      ]
    }
  }
}