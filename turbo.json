{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
     "env":["DATABASE_URL", "DIRECT_URL", "AUTH_SECRET", "REDIS_URL", "GCLOUD_PROJECT_ID", "GCLOUD_BUCKET", "GCS_CLIENT_EMAIL", "GCS_PRIVATE_KEY", "AI_API_KEY"],  
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
