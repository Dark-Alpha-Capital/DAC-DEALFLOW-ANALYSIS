# Optional: UF code for deal teaser/summary (teaser+description+comments on sync)
# BITRIX_DEAL_TEASER_UF="UF_CRM_xxxxxxxx"

# Google OAuth: Authorized redirect URI must be exactly:
#   {origin}/api/auth/callback/google   (e.g. http://localhost:3003/api/auth/callback/google)
AUTH_GOOGLE_ID=""

AUTH_GOOGLE_SECRET=""

GOOGLE_AI_API_KEY=""

# Public app URL — must match the browser origin (e.g. https://your-worker.workers.dev). Set in Cloudflare Worker vars for OAuth redirects (server) and optionally at vite build for SSR. Client uses current origin if unset (see lib/auth-client.ts).
VITE_PUBLIC_APP_URL=""

