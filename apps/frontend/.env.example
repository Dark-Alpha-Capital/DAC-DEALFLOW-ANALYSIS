
# Dev uses remote D1 + Vectorize + Workflows on the Cloudflare account from `wrangler login`.
# Run: bunx wrangler login && bun run dev

AI_API_KEY=""

BITRIX_SECRET_KEY=
BLOB_READ_WRITE_TOKEN=""

BITRIX24_WEBHOOK=""
# Deal opportunity sync (crm.deal.add / update)
# BITRIX24_PORTAL_BASE="https://yourcompany.bitrix24.com"
# BITRIX_DEFAULT_STAGE_ID=""
# Optional JSON array: [{"statusId":"C7:NEW","name":"New"}]
# BITRIX_DEAL_STAGES_JSON=""
# Optional: full JSON from packages/bitrix-sync/data/bitrix-deal-fields.json (crm.deal.fields snapshot)
# BITRIX_DEAL_FIELDS_JSON=""
# Optional: target Bitrix Disk location for IC readiness PDF reports. Folder wins over storage.
# BITRIX_IC_REPORT_FOLDER_ID=""
# BITRIX_IC_REPORT_STORAGE_ID=""
# Optional: UF code for deal teaser/summary (teaser+description+comments on sync)
# BITRIX_DEAL_TEASER_UF="UF_CRM_xxxxxxxx"
# Optional: override mapped UFs (defaults match packages/bitrix-sync/data/bitrix-deal-fields.json)
# BITRIX_UF_REVENUE="" BITRIX_UF_SOURCE_WEBSITE="" BITRIX_UF_COMPANY_LOCATION="" BITRIX_UF_ASKING_PRICE=""
# Broker UFs are empty by default — set to real UF_CRM_* from fetch-deal-fields if you sync brokers to custom fields:
# BITRIX_UF_BROKER_FIRST_NAME="" BITRIX_UF_BROKER_LAST_NAME="" BITRIX_UF_BROKER_EMAIL="" BITRIX_UF_BROKER_PHONE="" BITRIX_UF_BROKER_LINKEDIN=""

# Google OAuth redirect URIs (add both in Google Cloud Console):
#   http://localhost:3000/api/auth/callback/google          (local dev)
#   https://dealflow.darkalphacapital.com/api/auth/callback/google  (production)
AUTH_GOOGLE_ID=""

AUTH_GOOGLE_SECRET=""

GOOGLE_AI_API_KEY=""

# Local dev: http://localhost:3000. Production vars live in wrangler.jsonc.
VITE_PUBLIC_APP_URL=""

NEXT_PUBLIC_APP_URL=""

AUTH_SECRET=""

# Server-side auth base URL (OAuth redirects). Match browser origin in dev.
BETTER_AUTH_URL="http://localhost:3000"

# GTM Leads Ingest API - shared with GTM engineers for data scraping / deal sourcing
GTM_LEADS_API_KEY=""

# Optional — drizzle-kit push/studio against remote D1 (not used by the running app)
# CLOUDFLARE_ACCOUNT_ID="db3c8d159d12f92055af63054dfec052"
# CLOUDFLARE_D1_DATABASE_ID="ceeb42af-f9f3-4868-89ee-bf08dc6352a2"
# CLOUDFLARE_API_TOKEN=""

RESEND_API_KEY=""

NEXTCLOUD_URL=""
NEXTCLOUD_USER=""
NEXTCLOUD_PASSWORD=""

# Dev: TanStack Router + Query devtools (z-index overlay). Off by default so it cannot block clicks.
# VITE_ENABLE_TANSTACK_DEVTOOLS="true"
# VITE_DISABLE_TANSTACK_DEVTOOLS="true"
