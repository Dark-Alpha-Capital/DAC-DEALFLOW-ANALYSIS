{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "db": ["../../packages/db/index.ts"],
      "db/schema": ["../../packages/db/schema.ts"],
      "db/queries": ["../../packages/db/queries.ts"],
      "db/mutations": ["../../packages/db/mutations.ts"],
      "db/types": ["../../packages/db/types.ts"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
