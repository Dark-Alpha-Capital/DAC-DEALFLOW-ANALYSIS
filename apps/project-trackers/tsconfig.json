{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/hooks/*": ["./hooks/*"],
      "@repo/db-tracker": ["../../packages/db-tracker/index.ts"],
      "@repo/db-tracker/*": ["../../packages/db-tracker/*"],
      "@repo/enums": ["../../packages/enums/index.ts"],
      "@repo/schemas": ["../../packages/schemas/index.ts"],
      "@repo/ai-core": ["../../packages/ai-core/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/routeTree.gen.ts",
    "worker-configuration.d.ts"
  ]
}
