# Allow Plane sandboxed iframes (opaque/null origin) to load Vite ES modules.
# Module scripts require CORS; without these headers Extract/UI chunks never load.
/*
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Content-Security-Policy: frame-ancestors *

/assets/*
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=31536000, immutable
