# Worker-only deployment - place in dealflow/ on VPS as .env

# Required
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REDIS_URL=redis://:password@host:6379

# AI (required for screen-deal, cim-extraction, rag-ingestion)
AI_API_KEY=
GOOGLE_AI_API_KEY=
# Optional: for delete-file tool
GEMINI_API_KEY=

# Nextcloud (required for file-upload jobs)
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=

# Optional: frontend URL for callbacks (default: http://localhost:3000)
FRONTEND_URL=

# Optional
WORKER_PORT=8083
